# Copy this file to .env and fill in real values

# Server
PORT=5000
NODE_ENV=development

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD="Christ@Like123$"
DB_NAME=swing

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Seeded admin account (per spec)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin12345@

# OTP settings
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_LOCK_MINUTES=5

# Email (used to actually send OTP codes).
# If left blank, OTP codes are just printed to the server console (dev mode) instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Swing <no-reply@swing.app>

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
